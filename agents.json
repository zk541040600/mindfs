    {
      "name": "openclaw",
      "brief": "自托管个人 AI 助手，不只是 coding copilot；核心是把 WhatsApp、Telegram、Slack、日历、邮箱等渠道接到能实际执行任务的 agent gateway。",
      "installCommands": [
        { "os": ["darwin", "linux"], "command": "curl -fsSL https://openclaw.ai/install.sh | bash -s -- --no-onboard" },
        { "os": "windows", "command": "& ([scriptblock]::Create((iwr -useb https://openclaw.ai/install.ps1))) -NoOnboard" }
