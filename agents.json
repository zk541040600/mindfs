  "agents": [
    {
      "name": "gemini",
      "brief": "Google 的开源终端 agent，走 ReAct 循环调用本地工具和 MCP；强项是把 Gemini 的长上下文、多模态和 Google 搜索/生态能力直接放进 shell。",
      "installCommands": [
        { "os": ["darwin", "linux", "windows"], "command": "npm install -g @google/gemini-cli@latest" }
      ],
      "updateCommands": [
        { "os": ["darwin", "linux", "windows"], "command": "npm install -g @google/gemini-cli@latest" }
      ],
      "command": "gemini",
      "protocol": "acp",
      "args": [
        "--experimental-acp"
      ],
      "configBackup": {
        "fileSources": [
          "~/.gemini/.env",
          "~/.gemini/settings.json"
        ],
        "envKeys": [
          "GEMINI_API_KEY",
          "GOOGLE_GEMINI_BASE_URL",
          "GEMINI_MODEL"
        ]
      }
    },
    {
      "name": "codex",
      "brief": "OpenAI 的本地终端 coding agent，强调读代码、改文件、运行命令和测试；适合把明确的软件任务交给一个能在仓库里实际执行的 agent。",
      "installCommands": [
        { "os": ["darwin", "linux"], "command": "curl -fsSL https://chatgpt.com/codex/install.sh | sh" },
        { "os": "windows", "command": "irm https://chatgpt.com/codex/install.ps1 | iex" }
      ],
      "updateCommands": [
        { "os": ["darwin", "linux"], "command": "curl -fsSL https://chatgpt.com/codex/install.sh | CODEX_NON_INTERACTIVE=1 sh" },
        { "os": "windows", "command": "irm https://chatgpt.com/codex/install.ps1 | iex" }
      ],
      "command": "codex",
      "protocol": "codex-sdk",
      "configBackup": {
        "fileSources": [
          "~/.codex/auth.json",
          "~/.codex/config.toml"
        ]
      }
    },
    {
      "name": "claude",
      "brief": "Anthropic 的终端 coding agent，强在复杂推理、长期多步任务和代码库语义理解；常用于重构、调试、测试补齐和高风险改动前的确认式协作。",
      "installCommands": [
        { "os": ["darwin", "linux"], "command": "curl -fsSL https://claude.ai/install.sh | bash" },
        { "os": "windows", "command": "irm https://claude.ai/install.ps1 | iex" }
      ],
      "updateCommands": [
        { "os": ["darwin", "linux"], "command": "curl -fsSL https://claude.ai/install.sh | bash" },
        { "os": "windows", "command": "irm https://claude.ai/install.ps1 | iex" }
      ],
      "command": "claude",
      "protocol": "claude-sdk",
      "configBackup": {
        "envKeys": [
          "ANTHROPIC_AUTH_TOKEN",
          "ANTHROPIC_BASE_URL",
          "ANTHROPIC_API_KEY",
          "ANTHROPIC_MODEL",
          "ANTHROPIC_DEFAULT_HAIKU_MODEL",
          "ANTHROPIC_DEFAULT_SONNET_MODEL",
          "ANTHROPIC_DEFAULT_OPUS_MODEL",
          "AUTH_MODE"
        ]
      }
    },
    {
      "name": "cursor",
      "brief": "把 Cursor agent 带到终端、脚本和自动化流程；适合复用 Cursor 的代码上下文、MCP、headless 执行和带安全检查的 shell mode。",
      "installCommands": [
        { "os": ["darwin", "linux"], "command": "curl https://cursor.com/install -fsS | bash" },
        { "os": "windows", "command": "irm 'https://cursor.com/install?win32=true' | iex" }
      ],
      "updateCommands": [
        { "os": ["darwin", "linux"], "command": "curl https://cursor.com/install -fsS | bash" },
        { "os": "windows", "command": "irm 'https://cursor.com/install?win32=true' | iex" }
